rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Demo posture: any authenticated (anonymous) session has access.
    // NOTE: permissive. Tighten to per-owner once a backend mints Firebase
    // custom tokens bound to the Thai ID (anon uid rotates today, so
    // resource.data.uid checks would block returning users on reinstall).

    match /users/{userId} {
      allow read, write: if request.auth != null;

      match /loanRequests/{requestId} {
        allow read, write: if request.auth != null;
      }

      match /loans/{loanId} {
        allow read, write: if request.auth != null;

        match /payments/{paymentId} {
          allow read, write: if request.auth != null;
        }
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
